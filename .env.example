# .env.example — szablon zmiennych środowiskowych
# Skopiuj do .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env!

# Postgres/Neon connection string (wymagany)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# Apollo.io API (wymagany do funkcji "Uruchom kampanię Apollo")
APOLLO_API_KEY="your_apollo_api_key_here"

# ID sekwencji Apollo do której dodawani są kontakty (opcjonalny)
# Znajdziesz je w URL sekwencji w Apollo: https://app.apollo.io/#/sequences/<SEQUENCE_ID>
APOLLO_SEQUENCE_ID=""

# ID skrzynki nadawczej Apollo (wymagany przez API przy dodawaniu kontaktu do sekwencji)
# Znajdziesz je w Apollo: Settings → Mailboxes → kliknij skrzynkę → ID w URL
APOLLO_SENDER_EMAIL_ACCOUNT_ID=""

# (opcjonalnie) Lista mailboxów po przecinku — gdy masz wiele skrzynek
# Jeśli ustawione, pierwszy ID zostanie użyty jako nadawca (TODO: round-robin)
# APOLLO_SENDER_EMAIL_ACCOUNT_IDS="id1,id2,id3"

# Timeout runnera Apollo w sekundach (domyślnie 180)
# APOLLO_TIMEOUT=180

# Dozwolone origins CORS — domyślnie: https://profitia.github.io + localhost
# CORS_ORIGINS=https://profitia.github.io,http://localhost:8000

# Środowisko (development | production)
APP_ENV=production
