# .env.example — szablon zmiennych środowiskowych
# Skopiuj do .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env!

# Postgres/Neon connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# (opcjonalne) Dozwolone origins CORS dla API — domyślnie "*"
# CORS_ORIGINS=https://profitia.github.io

# Apollo auto pipeline — ścieżki do lokalnego workspacu (tylko lokalnie, Render nie ma dostępu)
# APOLLO_ROOT="/Users/tomaszuscinski/Documents/Visual Code Studio/Kampanie Apollo"
# APOLLO_PYTHON="/Users/tomaszuscinski/Documents/Visual Code Studio/Kampanie Apollo/.venv/bin/python"
# APOLLO_TIMEOUT=180
